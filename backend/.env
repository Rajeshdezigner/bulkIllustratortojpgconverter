PORT=5000
NODE_ENV=development

# Adobe Illustrator Path - Update this to your installation
ILLUSTRATOR_PATH=C:\Program Files (x86)\Adobe\Adobe Illustrator CS4\Support Files\Contents\Windows\Illustrator.exe

# Optional: Proxy settings if behind corporate firewall
# HTTP_PROXY=
# HTTPS_PROXY=

# --- Ollama (local AI for "AI Steps" — no OpenAI key needed) ---
# Install Ollama, run: ollama pull llama3.2  (already done if list shows llama3.2)
AI_PROVIDER=ollama
OLLAMA_MODEL=mistral
AI_JSON_MODE=1
# If you see "llama runner process has terminated", try: OLLAMA_MODEL=mistral
# CPU-only Ollama: set Windows system env OLLAMA_NUM_GPU=0, restart Ollama app
# OLLAMA_HOST=http://127.0.0.1:11434
